# EditorConfig configuration for xdp-router
# https://editorconfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# C source and header files
[*.{c,h}]
indent_style = tab
indent_size = 8
tab_width = 8

# Makefile
[Makefile]
indent_style = tab
indent_size = 8

# YAML files
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Python scripts (for future test scripts)
[*.py]
indent_style = space
indent_size = 4

# Shell scripts
[*.sh]
indent_style = tab
indent_size = 8
